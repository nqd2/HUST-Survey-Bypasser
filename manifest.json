{
  "manifest_version": 3,
  "name": "HUST Survey Auto-Bypass",
  "version": "1.0",
  "description": "Tự động điền survey HUST và bypass các câu hỏi.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cài đặt Survey"
  },
  "content_scripts": [
    {
      "matches": ["https://ctt-sis.hust.edu.vn/Surveys/dghp.aspx*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
